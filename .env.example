# --- Required -----------------------------------------------------------------

# CSC season number to poll. The worker fetches every match in this season,
# downloads each demo archive, and posts the parsed stats. Change this each
# season.
SEASON=19

# Base URL of the fragg-3.0 stats API (no trailing slash).
STATS_API_URL=https://your-fragg-3-0-api.example.com

# Bearer token accepted by the stats API's requireApiKey middleware.
# Must match the API_KEY env var on the stats API project.
STATS_API_KEY=

# --- Optional knobs -----------------------------------------------------------

# Match type filter passed to CSC. Defaults to "Regulation".
MATCH_TYPE=Regulation

# Override the CSC GraphQL endpoint (rarely needed).
CSC_GRAPHQL_URL=https://core.playcsc.com/graphql

# Maximum CSC matches to process in a single pass. Each match may contain
# multiple maps (each with its own .dem). Bound this if you want predictable
# pass duration; on a dedicated server it can safely be set very high
# because already-ingested matches are skipped via the GET pre-check.
MAX_MATCHES_PER_RUN=50

# Daemon-mode polling interval, in minutes.
#
#   - 0  (or unset): the worker runs ONE pass and exits. Use this when
#                    something else is driving the cadence (system cron,
#                    docker compose with `restart: "no"`, k8s CronJob, ...).
#   - >0:            the worker runs forever, sleeping this many minutes
#                    between passes. SIGINT / SIGTERM stop it cleanly.
CHECK_INTERVAL_MINUTES=30
